# ──────────────────────────────────────────────────────────────────────────────
# MaintainHub — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=maintainhub
POSTGRES_PASSWORD=maintainhub_dev
POSTGRES_DB=maintainhub_dev

# Full Prisma connection URL — used by Prisma CLI and the API
DATABASE_URL=postgresql://maintainhub:maintainhub_dev@localhost:5432/maintainhub_dev?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank to disable password (dev default)
REDIS_PASSWORD=

# ioredis / BullMQ connection URL
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible storage) ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_secret

MINIO_ENDPOINT=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=maintainhub

# Access key / secret for app-level SDK calls (can match root creds in dev)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev_secret

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_PORT=7700
MEILI_HOST=http://localhost:7700

# Master key must be ≥16 chars in production; dev key shown here is fine locally
MEILI_MASTER_KEY=maintainhub_meili_dev_master_key_32chars
MEILI_ENV=development
MEILI_LOG_LEVEL=WARN

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_me_with_64_hex_chars_access_secret
JWT_REFRESH_SECRET=replace_me_with_64_hex_chars_refresh_secret

# Token TTLs (ms-format strings accepted by ms package)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace_me

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@maintainhub.local
